# 依赖目录 - 不提交
node_modules/
miniprogram/node_modules/

# npm 构建产物 - 由微信开发者工具构建，可以不提交
# 如果团队协作需要，可以提交 miniprogram_npm
miniprogram/miniprogram_npm/

# 微信开发者工具配置
.project/

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 日志文件
*.log
npm-debug.log*

# 环境配置（可能包含敏感信息）
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.temp

# 打包文件
*.zip
*.rar

# 云函数依赖（需要单独处理）
cloudfunctions/*/node_modules/

# CodeBuddy 配置（AI 助手运行时文件，不需要提交）
.codebuddy/

# AI 规则文件（本地开发配置，不需要提交）
.rules/
rules/
