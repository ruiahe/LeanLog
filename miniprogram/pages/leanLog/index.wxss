/* 减肥打卡表单页面样式 */
/* ==================== 页面容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-color) 0%, var(--bg-secondary) 100%);
  padding-bottom: 40rpx;
}

/* ==================== 头部区域 ==================== */
.header {
  position: relative;
  padding: 30rpx 60rpx 80rpx;
  margin-bottom: 10rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 230rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  color: #FFFFFF;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-align: center;
}

.header-date {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.header-tip {
  font-size: 24rpx;
  opacity: 0.8;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  display: inline-block;
}

/* ==================== 快捷操作栏 ==================== */
.action-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

/* 操作按钮 */
.action-bar .action-btn {
  flex: 1;
}

/* ==================== 表单容器 ==================== */
.form-container {
  padding: 0 30rpx;
  position: relative;
  z-index: 2;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.form-card.collapsed {
  padding-bottom: 20rpx;
}

.card-content {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.3s ease, opacity 0.3s ease, margin 0.3s ease;
}

.card-content.expanded {
  max-height: 2000rpx;
  opacity: 1;
  margin-top: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #EEEEF0;
}

.card-header-clickable {
  justify-content: space-between;
  margin-bottom: 0;
  padding-bottom: 20rpx;
  transition: background-color 0.2s ease;
}

.card-header-clickable:active {
  background-color: var(--bg-secondary);
  border-radius: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-left: 16rpx;
  flex: 1;
}

.card-subtitle {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: 12rpx;
  font-weight: 400;
}

.card-arrow {
  margin-left: auto;
}

/* ==================== 卡片图标容器 ==================== */
.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-icon-weight {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: #FFFFFF;
}

.card-icon-diet {
  background: linear-gradient(135deg, #F5A623 0%, #FFD77A 100%);
  color: #FFFFFF;
}

.card-icon-exercise {
  background: linear-gradient(135deg, #FF6B6B 0%, #FFB3B3 100%);
  color: #FFFFFF;
}

.card-icon-sleep {
  background: linear-gradient(135deg, #8B5CF6 0%, #BFA3FA 100%);
  color: #FFFFFF;
}

.card-icon-night {
  background: linear-gradient(135deg, #5B8FF9 0%, #9BB8F7 100%);
  color: #FFFFFF;
}

.card-icon-body {
  background: linear-gradient(135deg, #13C2C2 0%, #76DEDE 100%);
  color: #FFFFFF;
}

/* ==================== 单位文字 ==================== */
.unit {
  color: var(--text-hint);
  font-size: 28rpx;
  padding-left: 8rpx;
}

/* ==================== 饥饿感标签 ==================== */
.hunger-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: flex-end;
}

.hunger-tag {
  margin: 0 !important;
  border-radius: 20rpx !important;
  padding: 8rpx 20rpx !important;
}

/* ==================== 提交按钮区域 ==================== */
.submit-area {
  padding: 40rpx 20rpx;
  margin-top: 24rpx;
}

/* ==================== Vant 组件样式覆盖 ==================== */
.form-card .van-cell-group--inset {
  margin: 0 !important;
  border-radius: 16rpx !important;
  border: none !important;
  overflow: hidden;
}

.form-card .van-cell-group {
  border: none !important;
}

.form-card .van-cell-group::before,
.form-card .van-cell-group::after {
  display: none !important;
}

.form-card .van-cell {
  padding: 0 20rpx !important;
  font-size: 28rpx !important;
  height: 100rpx !important;
  min-height: 100rpx !important;
  line-height: 100rpx !important;
  align-items: center !important;
  box-sizing: border-box !important;
}

/* 饥饿感行自适应高度 */
.form-card .hunger-cell {
  height: auto !important;
  min-height: auto !important;
  line-height: normal !important;
  padding: 24rpx 20rpx !important;
}

.form-card .hunger-cell .van-cell__value {
  height: auto !important;
  min-height: auto !important;
}

.form-card .van-field {
  padding: 0 20rpx !important;
  min-height: 100rpx !important;
  box-sizing: border-box !important;
}

/* textarea 类型的 field（饮食记录） */
.form-card .diet-field {
  height: auto !important;
  min-height: 120rpx !important;
}

.form-card .diet-field .van-cell__value {
  height: auto !important;
  min-height: 80rpx !important;
  padding-left: 10rpx;
}

.form-card .diet-field .van-field__body {
  height: auto !important;
  align-items: flex-start !important;
  padding-top: 16rpx !important;
}

/* textarea 类型的 field（今日备注） */
.form-card .notes-field {
  height: auto !important;
  min-height: 120rpx !important;
}

.form-card .notes-field .van-cell__value {
  height: auto !important;
  min-height: 80rpx !important;
  padding-left: 10rpx;
}

.form-card .notes-field .van-field__body {
  height: auto !important;
  align-items: flex-start !important;
  padding-top: 16rpx !important;
}

.form-card .van-field .van-cell__value {
  min-height: 100rpx !important;
  display: flex !important;
  align-items: center !important;
}

.form-card .van-field__body {
  min-height: 100% !important;
  display: flex !important;
  align-items: center !important;
}

/* 左侧标题/标签宽度统一 */
.form-card .van-field__label,
.form-card .van-cell__title {
  color: var(--text-secondary) !important;
  font-weight: 500;
  flex: none !important;
  width: 200rpx !important;
  min-width: 200rpx !important;
  max-width: 200rpx !important;
}

/* 右侧内容区域宽度统一 */
.form-card .van-cell__value {
  flex: 1 !important;
}

/* van-cell 右侧内容区域居中 */
.form-card .van-cell:not(.diet-field):not(.notes-field):not(.hunger-cell) .van-cell__value {
  height: 100rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: flex-end !important;
}

/* textarea 类型的 field 需要覆盖上面的固定高度 */
.form-card .van-cell.diet-field .van-cell__value,
.form-card .van-cell.notes-field .van-cell__value {
  height: auto !important;
  min-height: 80rpx !important;
}

.form-card .van-cell.diet-field .van-field__body,
.form-card .van-cell.notes-field .van-field__body {
  height: auto !important;
  align-items: flex-start !important;
  padding-top: 16rpx !important;
  width: 100% !important;
}

/* van-switch 居中 */
.form-card .van-switch {
  display: flex !important;
  align-items: center !important;
}

.form-card .van-field__control {
  font-size: 28rpx !important;
  color: var(--text-primary) !important;
}

.form-card .van-field__control::placeholder {
  color: #CCCCCC !important;
}

/* textarea placeholder 样式 */
.form-card .van-field__placeholder {
  color: #CCCCCC !important;
}

/* 按钮样式 - 主题自适应阴影 */
.submit-area .van-button--primary {
  height: 100rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx !important;
}

/* 评分组件样式 */
.form-card .van-rate {
  display: flex;
  gap: 8rpx;
}

/* ==================== 运动项样式 ==================== */
.exercise-item {
  background: var(--bg-color);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.exercise-item:last-of-type {
  margin-bottom: 0;
}

.exercise-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #EEEEF0;
}

.exercise-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.exercise-remove {
  padding: 8rpx;
}

.exercise-content {
  padding: 8rpx 0;
}

.exercise-type-selector,
.exercise-duration-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  height: 100rpx;
  min-height: 100rpx;
}

.type-label,
.duration-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  width: 200rpx;
  min-width: 200rpx;
  max-width: 200rpx;
  flex: none;
}

.type-value,
.duration-value {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: space-between;
}

.type-value text {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.type-value text.selected {
  color: var(--text-primary);
}

.type-value text.placeholder {
  color: var(--text-placeholder);
}

.duration-number {
  width: calc(100% - 60rpx);
  font-size: 28rpx;
  color: var(--text-primary);
}

.duration-unit {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
}

.add-exercise-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border: 2rpx dashed;
  border-radius: 20rpx;
  font-size: 28rpx;
  margin-top: 24rpx;
}

.add-exercise-btn text {
  margin-left: 8rpx;
}
