<!-- 减肥打卡表单页面 -->
<!-- 过滤 -->
<wxs src="../../utils/filters.wxs" module="filters" />

<!-- 登录授权弹窗 -->
<login-auth
  show="{{ showLoginPopup }}"
  theme-color="{{ currentTheme ? currentTheme.color : '#E8B4B8' }}"
  bind:loginsuccess="onLoginSuccess"
  bind:loginfail="onLoginFail"
/>

<view class="container" wx:if="currentTheme && record">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-bg" style="background: linear-gradient(135deg, {{ currentTheme.color }} 0%, {{ currentTheme.lightColor }} 100%);"></view>
    <view class="header-content">
      <view class="header-title">{{ filters.getTitle(currentDateTimestamp) }}</view>
      <view class="header-tip">{{ headerSubtitle }}</view>
    </view>
  </view>

  <!-- 表单主体 -->
  <view class="form-container">
    <!-- 快捷操作栏 -->
    <view class="action-bar">
      <streak-badge
        streak-days="{{ streakDays }}"
        theme-color="{{ currentTheme.color }}"
      />
      <back-to-today
        class="action-btn"
        wx:if="{{ !isToday }}"
        theme-color="{{ currentTheme.color }}"
        bind:backtotoday="goToToday"
      />
      <quick-fill
        class="action-btn"
        user-id="{{ userId }}"
        current-date-timestamp="{{ currentDateTimestamp }}"
        theme-color="{{ currentTheme.color }}"
        bind:fill="onQuickFill"
        bind:shownotify="onQuickFillNotify"
      />
    </view>

    <!-- 基础数据卡片 -->
    <view class="form-card">
      <view class="card-header">
        <van-icon name="chart-trending-o" size="18" color="{{ currentTheme.color }}" />
        <text class="card-title">基础数据</text>
      </view>
      <van-cell-group inset>
        <van-field
          value="{{ record.weight }}"
          type="digit"
          label="空腹体重"
          placeholder="请输入体重"
          border="{{ false }}"
          data-field="weight"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">kg</view>
        </van-field>
        <van-field
          value="{{ record.bodyFat }}"
          type="digit"
          label="体脂率"
          placeholder="请输入体脂率"
          border="{{ false }}"
          data-field="bodyFat"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">%</view>
        </van-field>
      </van-cell-group>
    </view>

    <!-- 饮食记录卡片 -->
    <view class="form-card">
      <view class="card-header">
        <van-icon name="balance-list-o" size="18" color="#F5A623" />
        <text class="card-title">饮食记录</text>
      </view>
      <van-cell-group inset>
        <van-cell title="是否按计划饮食" border="{{ false }}">
          <van-switch data-field="isHealthyDiet" checked="{{ record.isHealthyDiet }}" bind:change="onDataChange" active-color="{{ currentTheme.color }}" size="24px"/>
        </van-cell>
        <van-field
          value="{{ record.water }}"
          type="digit"
          label="饮水量"
          placeholder="请输入饮水量"
          border="{{ false }}"
          data-field="water"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">ml</view>
        </van-field>
        <van-field
          value="{{ record.diet }}"
          label="饮食记录"
          type="textarea"
          placeholder="你的饮食..."
          autosize
          border="{{ false }}"
          data-field="diet"
          bind:change="onDataChange"
          custom-class="diet-field"
        />
      </van-cell-group>
    </view>

    <!-- 运动记录卡片 -->
    <view class="form-card">
      <view class="card-header">
        <van-icon name="fire-o" size="18" color="#FF6B6B" />
        <text class="card-title">运动记录</text>
      </view>
      <van-cell-group inset>
        <van-field
          value="{{ record.stepNumber }}"
          type="digit"
          label="行走步数"
          placeholder="请输入步数"
          border="{{ false }}"
          data-field="stepNumber"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">步</view>
        </van-field>
        <van-cell title="是否运动" border="{{ false }}">
          <van-switch  data-field="exercised" checked="{{ record.exercised }}" bind:change="onExercisedChange" active-color="{{ currentTheme.color }}" size="24"/>
        </van-cell>

        <!-- 有氧运动列表 -->
        <block wx:if="{{ record.exercised }}">
          <view wx:for="{{ record.exerciseList }}" wx:key="id" class="exercise-item">
            <view class="exercise-header">
              <text class="exercise-label" style="color: {{ currentTheme.color }}">运动 {{ index + 1 }}</text>
              <view wx:if="{{ index > 0 }}" class="exercise-remove" bindtap="removeExercise" data-index="{{ index }}">
                <van-icon name="delete-o" size="16" color="{{ currentTheme.color }}" />
              </view>
            </view>
            <view class="exercise-content">
              <view class="exercise-type-selector" bindtap="showExerciseTypePicker" data-index="{{ index }}">
                <text class="type-label">运动类型</text>
                <view class="type-value">
                  <text class="{{ item.typeLabel ? 'selected' : 'placeholder' }}">
                    <text wx:if="{{ item.categoryName }}" class="type-category">{{ item.categoryName }} · </text>{{ item.typeLabel || '请选择' }}
                  </text>
                  <van-icon name="arrow" size="14" color="#999" />
                </view>
              </view>
              <view class="exercise-duration-input">
                <text class="duration-label">运动时长</text>
                <view class="duration-value">
                  <input
                    class="duration-number"
                    type="number"
                    value="{{ item.duration }}"
                    placeholder="请输入运动时长"
                    bindinput="onExerciseDurationInput"
                    data-index="{{ index }}"
                  />
                  <text class="duration-unit">分钟</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 添加运动按钮 -->
          <view class="add-exercise-btn" bindtap="addExercise" style="border-color: {{ currentTheme.color }}; color: {{ currentTheme.color }}">
            <van-icon name="plus" size="16" color="{{ currentTheme.color }}" />
            <text>添加运动</text>
          </view>
        </block>
      </van-cell-group>
    </view>

    <!-- 睡眠与状态卡片 -->
    <view class="form-card">
      <view class="card-header">
        <van-icon name="closed-eye" size="18" color="#8B5CF6" />
        <text class="card-title">睡眠与状态</text>
      </view>
      <van-cell-group inset>
        <!-- 昨夜睡眠 -->
        <van-field
          value="{{ record.sleepDuration }}"
          type="digit"
          label="昨夜睡眠"
          placeholder="请输入昨夜睡眠时长"
          border="{{ false }}"
          data-field="sleepDuration"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">小时</view>
        </van-field>
        <!-- 今日状态 -->
        <van-cell title="今日状态" border="{{ false }}">
          <van-rate data-field="mood" value="{{ record.mood }}" bind:change="onDataChange" size="24" color="#F5A623" void-color="#E8E8E8" gutter="2"/>
        </van-cell>
        <!-- 睡前饥饿感 -->
        <van-cell title="睡前饥饿感" border="{{ false }}" is-link="{{ false }}" clickable="{{ false }}" custom-class="hunger-cell">
          <view class="hunger-tags">
            <van-tag
              wx:for="{{ hungerOptions }}"
              wx:key="index"
              size="medium"
              type="default"
              color="{{ record.hunger === item.value ? currentTheme.color : '' }}"
              custom-class="hunger-tag"
              catchtap="selectHunger"
              data-value="{{ item.value }}"
            >
              {{ item.label }}
            </van-tag>
          </view>
        </van-cell>
      </van-cell-group>
    </view>

    <!-- 睡前数据卡片 -->
    <view class="form-card">
      <view class="card-header">
        <van-icon name="balance-list-o" size="18" color="#5B8FF9" />
        <text class="card-title">睡前数据</text>
      </view>
      <van-cell-group inset>
        <van-field
          value="{{ record.bedTimeWeight }}"
          type="digit"
          label="睡前体重"
          placeholder="请输入睡前体重"
          border="{{ false }}"
          data-field="bedTimeWeight"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">kg</view>
        </van-field>
        <van-field
          value="{{ record.notes }}"
          label="今日备注"
          type="textarea"
          placeholder="记录今天的感受、心情..."
          autosize
          border="{{ false }}"
          data-field="notes"
          bind:change="onDataChange"
          custom-class="notes-field"
        />
      </van-cell-group>
    </view>

    <!-- 三维记录卡片（每周记录） -->
    <view class="form-card {{ showMeasurements ? '' : 'collapsed' }}">
      <view class="card-header card-header-clickable" bindtap="toggleMeasurementsCard">
        <van-icon name="scan" size="18" color="#13C2C2" />
        <text class="card-title">三维记录</text>
        <text class="card-subtitle">每周记录一次</text>
        <van-icon name="{{ showMeasurements ? 'arrow-up' : 'arrow-down' }}" size="16" color="#999" class="card-arrow" />
      </view>
      <view class="card-content {{ showMeasurements ? 'expanded' : '' }}">
        <van-cell-group inset>
        <van-field
          value="{{ record.chest }}"
          type="digit"
          label="胸围"
          placeholder="请输入胸围"
          border="{{ false }}"
          data-field="chest"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">cm</view>
        </van-field>
        <van-field
          value="{{ record.waist }}"
          type="digit"
          label="腰围"
          placeholder="请输入腰围"
          border="{{ false }}"
          data-field="waist"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">cm</view>
        </van-field>
        <van-field
          value="{{ record.hip }}"
          type="digit"
          label="臀围"
          placeholder="请输入臀围"
          border="{{ false }}"
          data-field="hip"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">cm</view>
        </van-field>
        <van-field
          value="{{ record.arm }}"
          type="digit"
          label="上臂围"
          placeholder="请输入上臂围"
          border="{{ false }}"
          data-field="arm"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">cm</view>
        </van-field>
        <van-field
          value="{{ record.thigh }}"
          type="digit"
          label="大腿围"
          placeholder="请输入大腿围"
          border="{{ false }}"
          data-field="thigh"
          bind:change="onDataChange"
        >
          <view slot="right-icon" class="unit">cm</view>
        </van-field>
        </van-cell-group>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-area">
      <van-button type="primary" block round bind:click="submitForm" color="{{ currentTheme.color }}">
        保存打卡记录
      </van-button>
    </view>
  </view>

  <!-- 日期选择弹窗 -->
  <van-popup show="{{ showDatePickerPopup }}" position="bottom" round custom-style="overflow: visible;">
    <calendar
      selected-date="{{ currentDateTimestamp }}"
      record-dates="{{ recordDates }}"
      theme="{{ currentTheme }}"
      bind:confirm="onDateConfirm"
      bind:cancel="closeDialog"
    />
  </van-popup>

  <!-- 运动类型选择弹窗 -->
  <exercise-picker
    show-category="{{ showExerciseCategoryPopup }}"
    show-type="{{ showExerciseTypePopup }}"
    current-exercise="{{ record.currentExerciseIndex !== null ? record.exerciseList[record.currentExerciseIndex] : null }}"
    theme-color="{{ currentTheme.color }}"
    bind:selectcategory="onSelectCategory"
    bind:selecttype="onSelectType"
    bind:backtocategory="backToCategory"
    bind:closeCategory="closeDialog"
    bind:closeType="closeDialog"
  />

  <!-- 主题选择弹窗 -->
  <theme-picker
    show="{{ showThemePopup }}"
    current-theme-id="{{ currentTheme.id }}"
    bind:change="onThemeChange"
    bind:close="closeDialog"
  />

  <!-- Toast 提示 -->
  <van-toast id="van-toast" />

  <!-- Notify 弱提示 -->
  <van-notify id="van-notify" />

  <!-- 悬浮菜单组件 -->
  <float-menu
    id="floatMenu"
    theme="{{ currentTheme }}"
    menu-items="{{ floatMenuItems }}"
    bind:menutap="onFloatMenuTap"
  />
</view>
