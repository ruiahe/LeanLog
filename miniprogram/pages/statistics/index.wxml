<!-- 数据统计页面 -->
<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-bg" style="background: linear-gradient(135deg, {{ primaryColor }} 0%, {{ primaryColorLight }} 100%);"></view>
    <view class="header-content">
      <view class="header-title">数据统计</view>
      <view class="header-tip">查看你的健康数据变化趋势</view>
    </view>
  </view>

  <!-- 统计内容 -->
  <view class="stats-container">
    <!-- 加载状态 -->
    <van-loading wx:if="{{ loading }}" size="24px" vertical>加载中...</van-loading>

    <!-- 空状态 -->
    <van-empty wx:elif="{{ !loading && !hasRecords }}" description="暂无数据，快去打卡吧" />

    <!-- 数据统计内容 -->
    <block wx:else>
      <!-- 今日数据 -->
      <view class="overview-section">
        <view class="section-title">今日数据</view>
        <view class="overview-cards">
          <!-- 体重 -->
          <view class="overview-card">
            <view class="card-icon weight-icon">
              <van-icon name="balance-list-o" size="24" />
            </view>
            <view class="card-info">
              <view class="card-label">今日体重</view>
              <view class="card-value">{{ todayWeight != null ? todayWeight : '--' }} <text class="unit">kg</text></view>
              <view class="card-change {{ weightChange < 0 ? 'down' : weightChange > 0 ? 'up' : '' }}">
                <van-icon name="{{ weightChange < 0 ? 'arrow-down' : weightChange > 0 ? 'arrow-up' : 'minus' }}" size="12" />
                较昨日 {{ weightChangeText }}
              </view>
            </view>
          </view>
          <!-- 体脂率 -->
          <view class="overview-card">
            <view class="card-icon fat-icon">
              <van-icon name="certificate" size="24" />
            </view>
            <view class="card-info">
              <view class="card-label">今日体脂率</view>
              <view class="card-value">{{ todayBodyFat != null ? todayBodyFat : '--' }} <text class="unit">%</text></view>
              <view class="card-change {{ fatChange < 0 ? 'down' : fatChange > 0 ? 'up' : '' }}">
                <van-icon name="{{ fatChange < 0 ? 'arrow-down' : fatChange > 0 ? 'arrow-up' : 'minus' }}" size="12" />
                较昨日 {{ fatChangeText }}
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 打卡统计 -->
      <view class="stats-section">
        <view class="section-title">打卡统计</view>
        <view class="stats-cards">
          <view class="stat-card">
            <view class="stat-label">打卡天数</view>
            <view class="stat-value">{{ totalDays }}<text class="stat-unit">d</text></view>
          </view>
          <view class="stat-card">
            <view class="stat-label">连续打卡</view>
            <view class="stat-value">{{ streakDays }}<text class="stat-unit">d</text></view>
          </view>
          <view class="stat-card">
            <view class="stat-label">运动天数</view>
            <view class="stat-value">{{ exerciseDays }}<text class="stat-unit">d</text></view>
          </view>
          <view class="stat-card">
            <view class="stat-label">运动时长</view>
            <view class="stat-value">{{ totalExerciseMinutes }}<text class="stat-unit">min</text></view>
          </view>
          <view class="stat-card">
            <view class="stat-label">日均睡眠</view>
            <view class="stat-value">{{ avgSleep }}<text class="stat-unit">h</text></view>
          </view>
          <view class="stat-card">
            <view class="stat-label">日均饮水</view>
            <view class="stat-value">{{ avgWater }}<text class="stat-unit">ml</text></view>
          </view>
        </view>
      </view>

      <!-- 趋势图 -->
      <view class="chart-section">
        <view class="section-title">数据趋势</view>
        <!-- 选择器栏 -->
        <view class="picker-bar">
          <!-- 指标选择 -->
          <view class="picker-tag" bindtap="onShowMetricPicker">
            <text>{{ metricNames[metricIndex] }}</text>
            <van-icon name="arrow-down" size="12" />
          </view>
          <!-- 时间段选择 -->
          <view class="picker-tag date-range-tag" bindtap="onShowCalendar">
            <van-icon name="calendar-o" size="12" />
            <text>{{ dateRangeText }}</text>
          </view>
          <!-- 粒度选择 -->
          <view class="picker-tag" bindtap="onShowGranularityPicker">
            <text>{{ granularityNames[granularityIndex] }}</text>
            <van-icon name="arrow-down" size="12" />
          </view>
        </view>
        <!-- 图表 -->
        <view class="chart-container">
          <canvas
            canvas-id="trendChart"
            class="chart-canvas"
          ></canvas>
          <view class="chart-tips" wx:if="{{ !hasRecords }}">暂无数据</view>
        </view>
      </view>
    </block>
  </view>

  <!-- Notify 弱提示 -->
  <van-notify id="van-notify" />

  <!-- 指标选择弹窗 -->
  <van-popup show="{{ showMetricPicker }}" position="bottom" round bind:close="onCloseMetricPicker" custom-style="--picker-confirm-action-color: {{ primaryColor }};">
    <van-picker
      columns="{{ metricColumns }}"
      value-key="text"
      default-index="{{ metricIndex }}"
      show-toolbar
      title="选择指标"
      confirm-button-text="确定"
      cancel-button-text="取消"
      bind:confirm="onMetricConfirm"
      bind:cancel="onCloseMetricPicker"
    />
  </van-popup>

  <!-- 粒度选择弹窗 -->
  <van-popup show="{{ showGranularityPicker }}" position="bottom" round bind:close="onCloseGranularityPicker" custom-style="--picker-confirm-action-color: {{ primaryColor }};">
    <van-picker
      columns="{{ granularityColumns }}"
      value-key="text"
      default-index="{{ granularityIndex }}"
      show-toolbar
      title="选择粒度"
      confirm-button-text="确定"
      cancel-button-text="取消"
      bind:confirm="onGranularityConfirm"
      bind:cancel="onCloseGranularityPicker"
    />
  </van-popup>

  <!-- 日历弹窗 -->
  <van-popup show="{{ showCalendar }}" position="bottom" round bind:close="onCalendarClose">
    <calendar
      mode="range"
      range-start="{{ calendarRangeStart }}"
      range-end="{{ calendarRangeEnd }}"
      theme="{{ currentTheme }}"
      bind:confirm="onCalendarConfirm"
      bind:cancel="onCalendarClose"
    />
  </van-popup>

  <!-- 主题选择弹窗 -->
  <theme-picker
    show="{{ showThemePopup }}"
    current-theme-id="{{ currentTheme ? currentTheme.id : 'pink' }}"
    bind:change="onThemeChange"
    bind:close="closeThemePopup"
  />

  <!-- 悬浮菜单组件 -->
  <float-menu
    id="floatMenu"
    theme="{{ currentTheme }}"
    menu-items="{{ floatMenuItems }}"
    bind:menutap="onFloatMenuTap"
  />
</view>
