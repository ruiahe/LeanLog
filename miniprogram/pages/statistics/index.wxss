/* 数据统计页面样式 */
/* ==================== 页面容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-color) 0%, var(--bg-secondary) 100%);
  padding-bottom: 40rpx;
}

/* ==================== 头部区域 ==================== */
.header {
  position: relative;
  padding: 30rpx 60rpx 80rpx;
  margin-bottom: 10rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 230rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  color: #FFFFFF;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-align: center;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  display: inline-block;
  margin: 0 auto;
  text-align: center;
}

/* ==================== 统计容器 ==================== */
.stats-container {
  padding: 0 30rpx;
  position: relative;
  z-index: 2;
}

/* ==================== 区块标题 ==================== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* ==================== 今日数据 ==================== */
.overview-section {
  margin-bottom: 30rpx;
}

.overview-cards {
  display: flex;
  gap: 20rpx;
}

.overview-card {
  flex: 1;
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 图标容器 - 与打卡页统一 */
.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.weight-icon {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: #FFFFFF;
}

.fat-icon {
  background: linear-gradient(135deg, #5B8FF9 0%, #9BB8F7 100%);
  color: #FFFFFF;
}

.card-info {
  flex: 1;
}

.card-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.card-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
}

.card-value .unit {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-hint);
  margin-left: 4rpx;
}

.card-change {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.card-change.down {
  color: #07C160;
}

.card-change.up {
  color: #EE0A24;
}

/* ==================== 打卡统计 ==================== */
.stats-section {
  margin-bottom: 30rpx;
}

.stats-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
  line-height: 1.2;
}

.stat-unit {
  font-size: 22rpx;
  font-weight: 400;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* ==================== 趋势图 ==================== */
.chart-section {
  margin-bottom: 30rpx;
}

/* 选择器栏 */
.picker-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.picker-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--card-bg);
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.picker-tag text {
  white-space: nowrap;
}

/* 图表容器 */
.chart-container {
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.chart-canvas {
  width: 345px;
  height: 200px;
}

.chart-tips {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  color: var(--text-hint);
}
