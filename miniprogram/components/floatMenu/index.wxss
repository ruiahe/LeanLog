/* 悬浮菜单组件样式 */

/* 悬浮按钮 */
.floating-btn {
  position: fixed;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(232, 180, 184, 0.5);
  z-index: 100;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.floating-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(232, 180, 184, 0.4);
}

.floating-btn.active {
  transform: rotate(45deg);
}

/* 遮罩层 */
.tool-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  background: rgba(0, 0, 0, 0.3);
}

/* 工具菜单（动态扇形展开） */
.tool-menu {
  position: fixed;
  z-index: 95;
  pointer-events: none;
}

.tool-menu .tool-item {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0;
  transform-origin: center center;
  transform: scale(0);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  left: -44px;
  top: -44px;
}

.tool-menu.show .tool-item {
  opacity: 1;
  pointer-events: auto;
}

.tool-menu.show .tool-item-1 {
  transition-delay: 0.05s;
}

.tool-menu.show .tool-item-2 {
  transition-delay: 0.1s;
}

.tool-menu.show .tool-item-3 {
  transition-delay: 0.15s;
}

.tool-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-color, #E8B4B8) 0%, var(--primary-light, #F5D0D3) 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(232, 180, 184, 0.4);
  transition: transform 0.2s ease;
}

.tool-item:active .tool-icon {
  transform: scale(0.9);
}
