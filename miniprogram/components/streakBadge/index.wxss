/* 连续打卡天数徽章组件样式 */
.streak-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 18rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.streak-count {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.streak-label {
  font-size: 22rpx;
  font-weight: 500;
  opacity: 0.85;
}
