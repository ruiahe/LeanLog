/* 自定义日历组件样式 */
.calendar-container {
  background: var(--card-bg, #ffffff);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 月份切换头部 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx 24rpx;
  border-bottom: 2rpx solid var(--border-color, #f0f0f0);
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-secondary, #f8f8f8);
  transition: all 0.2s ease;
}

.nav-btn:active {
  transform: scale(0.95);
  background: var(--border-color, #eee);
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
}

/* 星期标题 */
.weekdays {
  display: flex;
  padding: 24rpx 0 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-hint, #999);
  font-weight: 500;
}

/* 日期网格 */
.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: calc(100% / 7);
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 8rpx;
}

.day-number {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-primary, #333);
  border-radius: 50%;
  transition: all 0.2s ease;
}

/* 其他月份日期 */
.day-item.other-month .day-number {
  color: var(--text-hint, #ccc);
}

/* 今天 */
.day-item.today .day-number {
  font-weight: 600;
}

/* 选中状态 */
.day-item.selected .day-number {
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(232, 180, 184, 0.4);
}

/* 有记录标记 */
.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary-color, #E8B4B8);
  position: absolute;
  bottom: 8rpx;
}

.day-item.selected .day-dot {
  background: #ffffff;
}

/* 未来日期 */
.day-item.future {
  opacity: 0.4;
}

/* ==================== Range 范围选择样式 ==================== */

/* 范围背景条 */
.range-bg {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 56rpx;
  transform: translateY(-50%);
  z-index: 0;
}

/* 范围起始：右侧半圆覆盖 */
.day-item.range-start .range-bg {
  left: 50%;
  border-radius: 0 28rpx 28rpx 0;
}

/* 范围结束：左侧半圆覆盖 */
.day-item.range-end .range-bg {
  right: 50%;
  border-radius: 28rpx 0 0 28rpx;
}

/* 起始和结束在同一天 */
.day-item.range-start.range-end .range-bg {
  left: 0;
  right: 0;
  border-radius: 28rpx;
}

/* 日期数字在范围背景之上 */
.day-item.range-start .day-number,
.day-item.range-end .day-number,
.day-item.in-range .day-number {
  position: relative;
  z-index: 1;
}

/* 范围内圆点颜色 */
.day-item.in-range .day-dot {
  background: var(--primary-color, #E8B4B8);
}

/* 底部按钮 */
.calendar-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--border-color, #f0f0f0);
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.btn-cancel {
  background: var(--bg-secondary, #f5f5f5);
  color: var(--text-secondary, #666);
}

.btn-cancel:active {
  background: var(--border-color, #eee);
}

.btn-confirm {
  color: #ffffff;
}

.btn-confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}
