/* 回到今天组件样式 */
.back-to-today {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 100%;
  padding: 14rpx 0;
  border-radius: 24rpx;
  border: 2rpx solid;
  background: var(--card-bg);
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.back-to-today text {
  font-size: 24rpx;
  font-weight: 500;
}

.back-to-today:active {
  background: var(--bg-secondary, #EDF2F7);
  transform: scale(0.97);
}
